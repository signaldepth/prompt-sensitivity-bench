{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contributor",
  "type": "object",
  "required": ["id"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "name": {"type": "string", "minLength": 1},
    "github": {"type": "string", "minLength": 1},
    "url": {"type": "string", "minLength": 1},
    "notes": {"type": "string"},
    "models": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
