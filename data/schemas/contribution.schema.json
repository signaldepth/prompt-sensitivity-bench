{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Contribution",
  "type": "object",
  "required": ["experiment", "model_name", "temperature", "k", "results"],
  "properties": {
    "experiment": {"const": "e9_specificity"},
    "model_name": {"type": "string", "minLength": 1},
    "model_provider": {"type": "string", "minLength": 1},
    "model_hardware": {"type": "string", "minLength": 1},
    "temperature": {"type": "number"},
    "k": {"type": "integer", "minimum": 3},
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level", "avg_pass_rate"],
        "properties": {
          "task": {"type": "string", "minLength": 1},
          "level": {
            "enum": ["vague", "task_only", "task_io", "full_spec"]
          },
          "model": {"type": "string", "minLength": 1},
          "model_name": {"type": "string", "minLength": 1},
          "avg_pass_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "pass_rates": {
            "type": "array",
            "items": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        }
      }
    }
  }
}
